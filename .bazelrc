# ── Bzlmod ────────────────────────────────────────────────────────────────────
common --enable_bzlmod

# Windows runfiles are required by rules_foreign_cc's built pkg-config toolchain.
build --enable_runfiles

# ── C++20 ─────────────────────────────────────────────────────────────────────
build --cxxopt=-std=c++20
build --cxxopt=-Wall
build:linux --cxxopt=-Wextra
build:macos --cxxopt=-Wextra
build:windows --cxxopt=/std:c++20
build:windows --cxxopt=/W3
build:windows --cxxopt=/EHsc

# ── Platform detection ────────────────────────────────────────────────────────
build --enable_platform_specific_config
build --incompatible_enable_cc_toolchain_resolution

# ── rules_foreign_cc: sandboxing ─────────────────────────────────────────────
build --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=0

# ── Windows shell for rules_foreign_cc ────────────────────────────────────────
# Prefer Git Bash when available so Bazel does not pick the WSL bash.exe stub.
# Override this in .bazelrc.user if your shell lives elsewhere.
build:windows --action_env=BAZEL_SH=C:/PROGRA~1/Git/bin/bash.exe
build:windows --action_env=PATH=C:/PROGRA~1/Git/bin;C:/PROGRA~1/Git/usr/bin;C:/WINDOWS/system32;C:/WINDOWS;C:/WINDOWS/System32/WindowsPowerShell/v1.0
build:windows --host_action_env=BAZEL_SH=C:/PROGRA~1/Git/bin/bash.exe
build:windows --host_action_env=PATH=C:/PROGRA~1/Git/bin;C:/PROGRA~1/Git/usr/bin;C:/WINDOWS/system32;C:/WINDOWS;C:/WINDOWS/System32/WindowsPowerShell/v1.0

# ── Optional: use a local .bazelrc.user for machine-specific overrides ────────
try-import .bazelrc.user
